---
import Layout from '../layouts/Layout.astro';

const modules = [
  {
    name: 'Workloads',
    status: 'live',
    description: 'Self-service app onboarding. Import a GitHub repo, auto-detect the framework, deploy to Kubernetes. No tickets.',
  },
  {
    name: 'Assure',
    status: 'live',
    description: 'Test automation built into the platform. Write, manage, and run tests with a local browser — free forever.',
  },
  {
    name: 'Plate Assistant',
    status: 'live',
    description: 'AI assistant that understands your platform. Deploy apps, check clusters, run operations — in plain English.',
  },
  {
    name: 'Origin',
    status: 'beta',
    description: 'Infrastructure resource catalogue. Every cloud resource and Kubernetes namespace, with ownership and cost visibility.',
  },
  {
    name: 'Flows',
    status: 'beta',
    description: 'Platform automation pipelines. Approval flows, runbooks, and self-service workflows — without scripting everything.',
  },
  {
    name: 'Agent Factory',
    status: 'soon',
    description: 'Govern every AI agent your teams are building — on AWS Bedrock, Azure AI, GCP Vertex, or local. One control plane.',
  },
];

const statusLabel: Record<string, string> = {
  live: 'Live',
  beta: 'Beta',
  soon: 'Coming soon',
};
---
<Layout>

<!-- subtle dot grid -->
<div class="fixed inset-0 bg-[radial-gradient(rgba(15,23,42,0.06)_1px,transparent_1px)] dark:bg-[radial-gradient(rgba(148,163,184,0.05)_1px,transparent_1px)] bg-[size:28px_28px] pointer-events-none"></div>

<!-- NAV -->
<header class="relative z-10 max-w-2xl mx-auto px-6 pt-8 pb-0 flex items-center justify-between">
  <a href="/" class="flex items-center gap-2.5">
    <svg class="w-6 h-6" viewBox="0 0 32 32" fill="none">
      <rect width="32" height="32" rx="7" fill="#4f46e5"/>
      <path d="M8 10h10a6 6 0 0 1 0 12H8V10z" fill="white" opacity="0.9"/>
      <rect x="8" y="14" width="16" height="2.5" rx="1.25" fill="#4f46e5"/>
    </svg>
    <span class="font-semibold text-slate-900 dark:text-white tracking-tight">Plate</span>
  </a>
  <div class="flex items-center gap-5">
    <a href="https://discord.gg/7ErWeqyPHn" target="_blank"
       class="text-slate-500 hover:text-slate-800 dark:hover:text-slate-300 text-sm transition-colors">
      Discord
    </a>
    <a href="https://github.com/plate-platform" target="_blank"
       class="text-slate-500 hover:text-slate-800 dark:hover:text-slate-300 text-sm transition-colors font-mono">
      GitHub →
    </a>
    <!-- theme toggle -->
    <button id="theme-toggle" aria-label="Toggle theme"
            class="w-8 h-8 flex items-center justify-center rounded-lg text-slate-400 hover:text-slate-700 dark:hover:text-slate-200 hover:bg-slate-100 dark:hover:bg-white/8 transition-colors">
      <svg class="hidden dark:block w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
          d="M12 3v1m0 16v1m8.66-9H21M3 12H2m15.07-6.07-.71.71M6.64 17.36l-.71.71M17.36 17.36l.71.71M6.64 6.64l.71.71M12 7a5 5 0 1 0 0 10A5 5 0 0 0 12 7z"/>
      </svg>
      <svg class="block dark:hidden w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
          d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
      </svg>
    </button>
  </div>
</header>

<!-- HERO -->
<main class="relative z-10 max-w-2xl mx-auto px-6 pt-20 pb-16">

  <div class="flex items-center gap-2 text-xs text-slate-400 dark:text-slate-500 mb-8 font-mono">
    <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
    building in public · v0.1
  </div>

  <h1 class="text-4xl sm:text-5xl font-bold text-slate-900 dark:text-white tracking-tight leading-[1.1] mb-6">
    An open internal developer<br class="hidden sm:block"/> platform for the AI era.
  </h1>

  <p class="text-slate-600 dark:text-slate-400 text-lg leading-relaxed mb-4 max-w-xl">
    We got tired of developers waiting on tickets to deploy, platform teams buried in YAML,
    and AI agents proliferating across three clouds with nobody tracking what they cost or what they could touch.
  </p>

  <p class="text-slate-600 dark:text-slate-400 text-lg leading-relaxed mb-4 max-w-xl">
    Plate is our fix — an open platform that unifies app delivery, infrastructure management,
    and AI agent governance. Open source. Runs on your Kubernetes cluster.
  </p>

  <p class="text-slate-400 dark:text-slate-600 text-sm font-mono mb-10">
    Still early. We're shipping fast.<span class="inline-block w-0.5 h-3.5 bg-slate-400 dark:bg-slate-500 ml-0.5 align-middle animate-[blink_1s_step-end_infinite]"></span>
  </p>

  <div class="flex flex-wrap items-center gap-4 text-sm">
    <a href="https://discord.gg/7ErWeqyPHn" target="_blank"
       class="px-5 py-2.5 rounded-lg bg-indigo-600 hover:bg-indigo-500 text-white font-medium transition-colors">
      Join the Discord
    </a>
    <a href="https://github.com/plate-platform" target="_blank"
       class="px-5 py-2.5 rounded-lg border border-slate-200 dark:border-white/10 hover:border-slate-300 dark:hover:border-white/20 text-slate-700 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white font-medium transition-colors">
      GitHub
    </a>
    <a href="#modules"
       class="text-slate-400 dark:text-slate-500 hover:text-slate-800 dark:hover:text-white transition-colors">
      What we're building ↓
    </a>
  </div>

</main>

<!-- MODULES -->
<section id="modules" class="relative z-10 max-w-2xl mx-auto px-6 pb-24">

  <p class="text-xs font-mono text-slate-400 dark:text-slate-600 uppercase tracking-widest mb-5">What we're building</p>

  <div class="border border-slate-200 dark:border-white/8 rounded-xl overflow-hidden divide-y divide-slate-200 dark:divide-white/5 bg-white dark:bg-transparent">
    {modules.map((m) => (
      <div class="flex items-start gap-4 px-5 py-4 hover:bg-slate-50 dark:hover:bg-white/[0.02] transition-colors">
        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-2.5 mb-1">
            <span class="text-slate-900 dark:text-white font-medium text-sm">{m.name}</span>
            <span class:list={[
              'px-1.5 py-0.5 rounded text-xs font-mono',
              m.status === 'live' && 'bg-emerald-50 dark:bg-emerald-500/10 text-emerald-700 dark:text-emerald-400',
              m.status === 'beta' && 'bg-amber-50 dark:bg-amber-500/10 text-amber-700 dark:text-amber-400',
              m.status === 'soon' && 'bg-slate-100 dark:bg-slate-700/60 text-slate-500 dark:text-slate-500',
            ]}>
              {statusLabel[m.status]}
            </span>
          </div>
          <p class="text-slate-500 dark:text-slate-500 text-sm leading-relaxed">{m.description}</p>
        </div>
      </div>
    ))}
  </div>

</section>

<!-- TECH STACK (subtle) -->
<section class="relative z-10 max-w-2xl mx-auto px-6 pb-24">
  <p class="text-xs font-mono text-slate-400 dark:text-slate-600 uppercase tracking-widest mb-4">Built on</p>
  <p class="text-slate-400 dark:text-slate-600 text-sm leading-loose">
    {['Go', 'Kubernetes', 'ArgoCD', 'Crossplane', 'Helm', 'Vue 3', 'MCP Protocol'].join('  ·  ')}
  </p>
</section>

<!-- FOOTER -->
<footer class="relative z-10 max-w-2xl mx-auto px-6 pb-10 pt-6 border-t border-slate-200 dark:border-white/5">
  <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3 text-xs text-slate-400 dark:text-slate-600">
    <span class="font-mono">Plate Platform · Apache 2.0</span>
    <div class="flex items-center gap-5">
      <a href="https://github.com/plate-platform" target="_blank" class="hover:text-slate-700 dark:hover:text-slate-400 transition-colors">GitHub</a>
      <a href="https://github.com/plate-platform/plate-platform/blob/main/README.md" target="_blank" class="hover:text-slate-700 dark:hover:text-slate-400 transition-colors">Docs</a>
      <a href="https://github.com/plate-platform/plate-platform/issues" target="_blank" class="hover:text-slate-700 dark:hover:text-slate-400 transition-colors">Issues</a>
      <a href="https://discord.gg/7ErWeqyPHn" target="_blank" class="hover:text-slate-700 dark:hover:text-slate-400 transition-colors">Discord</a>
    </div>
  </div>
</footer>

<style>
  @keyframes blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }
</style>

<script>
  const toggle = document.getElementById('theme-toggle');
  toggle?.addEventListener('click', () => {
    const isDark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
  });
</script>

</Layout>
