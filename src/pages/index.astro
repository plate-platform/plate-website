---
import Layout from '../layouts/Layout.astro';
---
<Layout>

<!-- ─── NAV ────────────────────────────────────────────────────────────────── -->
<header class="fixed top-0 inset-x-0 z-50 border-b border-white/5 bg-slate-950/80 backdrop-blur-xl">
  <nav class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2.5">
      <svg class="w-7 h-7" viewBox="0 0 32 32" fill="none">
        <rect width="32" height="32" rx="7" fill="#4f46e5"/>
        <path d="M8 10h10a6 6 0 0 1 0 12H8V10z" fill="white" opacity="0.9"/>
        <rect x="8" y="14" width="16" height="2.5" rx="1.25" fill="#4f46e5"/>
      </svg>
      <span class="font-bold text-lg tracking-tight text-white">Plate</span>
    </a>
    <div class="hidden md:flex items-center gap-8 text-sm font-medium text-slate-400">
      <a href="#platform" class="hover:text-white transition-colors">Platform</a>
      <a href="#agent-factory" class="hover:text-white transition-colors">Agent Factory</a>
      <a href="#assistant" class="hover:text-white transition-colors">AI Assistant</a>
      <a href="#for-who" class="hover:text-white transition-colors">Who It's For</a>
    </div>
    <a href="https://github.com/plate-platform" target="_blank"
       class="hidden md:flex items-center gap-2 px-4 py-2 rounded-lg bg-plate-600 hover:bg-plate-500 text-white text-sm font-medium transition-colors">
      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
      GitHub
    </a>
  </nav>
</header>

<!-- ─── HERO ────────────────────────────────────────────────────────────────── -->
<section class="relative min-h-screen flex items-center justify-center overflow-hidden pt-16">
  <!-- background glow -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute top-1/4 left-1/2 -translate-x-1/2 w-[900px] h-[600px] bg-plate-600/20 rounded-full blur-[120px]"></div>
    <div class="absolute top-1/2 left-1/4 w-[400px] h-[400px] bg-violet-600/10 rounded-full blur-[100px]"></div>
    <div class="absolute top-1/3 right-1/4 w-[300px] h-[300px] bg-indigo-400/10 rounded-full blur-[80px]"></div>
    <!-- grid -->
    <div class="absolute inset-0 bg-[linear-gradient(rgba(99,102,241,0.04)_1px,transparent_1px),linear-gradient(90deg,rgba(99,102,241,0.04)_1px,transparent_1px)] bg-[size:64px_64px]"></div>
  </div>

  <div class="relative max-w-5xl mx-auto px-6 text-center">
    <div class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-full border border-plate-500/30 bg-plate-500/10 text-plate-300 text-sm font-medium mb-8">
      <span class="w-2 h-2 rounded-full bg-plate-400 animate-pulse-slow"></span>
      Open Platform Engineering for the AI Era
    </div>

    <h1 class="text-5xl sm:text-6xl lg:text-7xl font-extrabold tracking-tight leading-[1.05] mb-6">
      <span class="text-white">The platform your</span><br/>
      <span class="bg-gradient-to-r from-plate-400 via-violet-400 to-indigo-300 bg-clip-text text-transparent">engineering teams deserve</span>
    </h1>

    <p class="text-xl text-slate-400 max-w-2xl mx-auto mb-10 leading-relaxed">
      Plate is an open internal developer platform that unifies application delivery,
      infrastructure management, and AI agent governance — in one place, on your infrastructure.
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a href="https://github.com/plate-platform" target="_blank"
         class="px-8 py-3.5 rounded-xl bg-plate-600 hover:bg-plate-500 text-white font-semibold text-base transition-all hover:shadow-lg hover:shadow-plate-600/25">
        Get Started on GitHub →
      </a>
      <a href="#platform"
         class="px-8 py-3.5 rounded-xl border border-white/10 hover:border-white/20 text-slate-300 hover:text-white font-semibold text-base transition-all hover:bg-white/5">
        See the Platform
      </a>
    </div>

    <!-- stat pills -->
    <div class="mt-16 flex flex-wrap items-center justify-center gap-4 text-sm">
      {[
        ['Kubernetes-native', 'No external database'],
        ['GitOps-first', 'ArgoCD + Crossplane'],
        ['AI-ready', 'Agents + MCP + LLMs'],
        ['Open source', 'Apache 2.0'],
      ].map(([label, sub]) => (
        <div class="flex items-center gap-3 px-4 py-2.5 rounded-lg bg-white/5 border border-white/8">
          <div class="w-2 h-2 rounded-full bg-plate-400"></div>
          <div class="text-left">
            <div class="text-white font-medium">{label}</div>
            <div class="text-slate-500 text-xs">{sub}</div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ─── PROBLEM ─────────────────────────────────────────────────────────────── -->
<section class="py-28 border-t border-white/5">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">Platform engineering is broken</h2>
      <p class="text-slate-400 text-lg max-w-2xl mx-auto">
        Teams stitch together dozens of tools. Nothing talks to each other. Developers wait on tickets instead of shipping.
      </p>
    </div>
    <div class="grid md:grid-cols-3 gap-6">
      {[
        {
          icon: '🔧',
          title: 'Too many tools, no coherence',
          body: 'Jira for tickets, Confluence for docs, Jenkins for CI, Argo for deploy, PagerDuty for alerts. Every team has a different stack and nobody can see the full picture.',
        },
        {
          icon: '⏳',
          title: 'Developers wait on platform teams',
          body: 'Every new app, environment, or cloud resource is a ticket. Platform teams are the bottleneck. Developers lose days waiting for access they should self-serve in minutes.',
        },
        {
          icon: '🤖',
          title: 'AI agents with no governance',
          body: 'Teams are building AI agents on AWS, Azure, and internally. Nobody knows what they cost, what data they access, or who owns them. The governance gap grows every week.',
        },
      ].map(item => (
        <div class="p-6 rounded-2xl bg-white/4 border border-white/8 hover:border-white/15 transition-colors">
          <div class="text-3xl mb-4">{item.icon}</div>
          <h3 class="text-white font-semibold text-lg mb-2">{item.title}</h3>
          <p class="text-slate-400 leading-relaxed">{item.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ─── PLATFORM OVERVIEW ───────────────────────────────────────────────────── -->
<section id="platform" class="py-28 border-t border-white/5">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-16">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-plate-500/10 border border-plate-500/20 text-plate-300 text-sm font-medium mb-4">
        The Platform
      </div>
      <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">
        Everything platform engineering needs.<br/>Nothing you don't.
      </h2>
      <p class="text-slate-400 text-lg max-w-2xl mx-auto">
        One portal. Your infrastructure. Teams ship autonomously while the platform team stays in control.
      </p>
    </div>

    <!-- modules grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">

      <!-- Workloads -->
      <div class="group relative p-6 rounded-2xl bg-gradient-to-b from-white/6 to-white/3 border border-white/10 hover:border-plate-500/40 transition-all hover:shadow-lg hover:shadow-plate-900/20">
        <div class="w-10 h-10 rounded-xl bg-plate-600/20 flex items-center justify-center mb-4 text-plate-300 group-hover:bg-plate-600/30 transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M12 5l7 7-7 7"/></svg>
        </div>
        <div class="flex items-center gap-2 mb-2">
          <h3 class="text-white font-semibold text-lg">Workloads</h3>
          <span class="px-2 py-0.5 rounded text-xs font-medium bg-emerald-500/15 text-emerald-400 border border-emerald-500/20">Live</span>
        </div>
        <p class="text-slate-400 text-sm leading-relaxed">
          Self-service application onboarding. Import a GitHub repo, auto-detect the framework, generate a Helm chart, and deploy to Kubernetes in minutes. No tickets required.
        </p>
        <ul class="mt-4 space-y-1.5 text-xs text-slate-500">
          <li class="flex items-center gap-2"><span class="text-plate-400">✓</span> GitHub + Gitea integration</li>
          <li class="flex items-center gap-2"><span class="text-plate-400">✓</span> Auto-detect Spring Boot, Flask, Node.js, Go</li>
          <li class="flex items-center gap-2"><span class="text-plate-400">✓</span> Helm chart generation + ChartMuseum publish</li>
        </ul>
      </div>

      <!-- Origin -->
      <div class="group relative p-6 rounded-2xl bg-gradient-to-b from-white/6 to-white/3 border border-white/10 hover:border-violet-500/40 transition-all hover:shadow-lg hover:shadow-violet-900/20">
        <div class="w-10 h-10 rounded-xl bg-violet-600/20 flex items-center justify-center mb-4 text-violet-300 group-hover:bg-violet-600/30 transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"/></svg>
        </div>
        <div class="flex items-center gap-2 mb-2">
          <h3 class="text-white font-semibold text-lg">Origin</h3>
          <span class="px-2 py-0.5 rounded text-xs font-medium bg-amber-500/15 text-amber-400 border border-amber-500/20">Beta</span>
        </div>
        <p class="text-slate-400 text-sm leading-relaxed">
          Infrastructure resource catalogue. See every cloud resource, Kubernetes namespace, and managed service across your organisation — with ownership and cost visibility.
        </p>
        <ul class="mt-4 space-y-1.5 text-xs text-slate-500">
          <li class="flex items-center gap-2"><span class="text-violet-400">✓</span> Crossplane-backed resource management</li>
          <li class="flex items-center gap-2"><span class="text-violet-400">✓</span> Multi-cluster visibility</li>
          <li class="flex items-center gap-2"><span class="text-violet-400">✓</span> Cost attribution per team</li>
        </ul>
      </div>

      <!-- Flows -->
      <div class="group relative p-6 rounded-2xl bg-gradient-to-b from-white/6 to-white/3 border border-white/10 hover:border-cyan-500/40 transition-all hover:shadow-lg hover:shadow-cyan-900/20">
        <div class="w-10 h-10 rounded-xl bg-cyan-600/20 flex items-center justify-center mb-4 text-cyan-300 group-hover:bg-cyan-600/30 transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
        </div>
        <div class="flex items-center gap-2 mb-2">
          <h3 class="text-white font-semibold text-lg">Flows</h3>
          <span class="px-2 py-0.5 rounded text-xs font-medium bg-amber-500/15 text-amber-400 border border-amber-500/20">Beta</span>
        </div>
        <p class="text-slate-400 text-sm leading-relaxed">
          Platform automation pipelines. Define approval flows, runbooks, and self-service workflows for common operations — without scripting everything from scratch.
        </p>
        <ul class="mt-4 space-y-1.5 text-xs text-slate-500">
          <li class="flex items-center gap-2"><span class="text-cyan-400">✓</span> Visual workflow builder</li>
          <li class="flex items-center gap-2"><span class="text-cyan-400">✓</span> Approval gates + notifications</li>
          <li class="flex items-center gap-2"><span class="text-cyan-400">✓</span> Kubernetes-native execution</li>
        </ul>
      </div>

      <!-- Assure -->
      <div class="group relative p-6 rounded-2xl bg-gradient-to-b from-white/6 to-white/3 border border-white/10 hover:border-green-500/40 transition-all hover:shadow-lg hover:shadow-green-900/20">
        <div class="w-10 h-10 rounded-xl bg-green-600/20 flex items-center justify-center mb-4 text-green-300 group-hover:bg-green-600/30 transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
        </div>
        <div class="flex items-center gap-2 mb-2">
          <h3 class="text-white font-semibold text-lg">Assure</h3>
          <span class="px-2 py-0.5 rounded text-xs font-medium bg-emerald-500/15 text-emerald-400 border border-emerald-500/20">Live</span>
        </div>
        <p class="text-slate-400 text-sm leading-relaxed">
          Quality and compliance automation. Run browser-based tests, validate deployments, and enforce policy gates before anything reaches production.
        </p>
        <ul class="mt-4 space-y-1.5 text-xs text-slate-500">
          <li class="flex items-center gap-2"><span class="text-green-400">✓</span> Cloud browser automation</li>
          <li class="flex items-center gap-2"><span class="text-green-400">✓</span> AI-assisted test generation</li>
          <li class="flex items-center gap-2"><span class="text-green-400">✓</span> Policy enforcement gates</li>
        </ul>
      </div>

      <!-- Plate Assistant -->
      <div class="group relative p-6 rounded-2xl bg-gradient-to-b from-white/6 to-white/3 border border-white/10 hover:border-indigo-500/40 transition-all hover:shadow-lg hover:shadow-indigo-900/20">
        <div class="w-10 h-10 rounded-xl bg-indigo-600/20 flex items-center justify-center mb-4 text-indigo-300 group-hover:bg-indigo-600/30 transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/></svg>
        </div>
        <div class="flex items-center gap-2 mb-2">
          <h3 class="text-white font-semibold text-lg">Plate Assistant</h3>
          <span class="px-2 py-0.5 rounded text-xs font-medium bg-emerald-500/15 text-emerald-400 border border-emerald-500/20">Live</span>
        </div>
        <p class="text-slate-400 text-sm leading-relaxed">
          An AI assistant that understands your platform. Deploy apps, check infrastructure, and run platform operations through natural language — powered by Claude, Gemini, or local models.
        </p>
        <ul class="mt-4 space-y-1.5 text-xs text-slate-500">
          <li class="flex items-center gap-2"><span class="text-indigo-400">✓</span> 70+ platform tools via MCP</li>
          <li class="flex items-center gap-2"><span class="text-indigo-400">✓</span> Works with Claude Desktop, VS Code, Cline</li>
          <li class="flex items-center gap-2"><span class="text-indigo-400">✓</span> Local models via Ollama — no cloud required</li>
        </ul>
      </div>

      <!-- Agent Factory -->
      <div class="group relative p-6 rounded-2xl bg-gradient-to-b from-plate-900/40 to-violet-900/20 border border-plate-500/30 hover:border-plate-400/60 transition-all hover:shadow-xl hover:shadow-plate-900/30">
        <div class="absolute top-3 right-3">
          <span class="px-2 py-0.5 rounded text-xs font-medium bg-plate-500/20 text-plate-300 border border-plate-500/30">Coming Soon</span>
        </div>
        <div class="w-10 h-10 rounded-xl bg-plate-600/30 flex items-center justify-center mb-4 text-plate-300 group-hover:bg-plate-600/40 transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v18m0 0h10a2 2 0 002-2V9M9 21H5a2 2 0 01-2-2V9m0 0h18"/></svg>
        </div>
        <h3 class="text-white font-semibold text-lg mb-2">Agent Factory</h3>
        <p class="text-slate-400 text-sm leading-relaxed">
          The control plane for AI agents your teams are already building. Govern every agent — local, AWS Bedrock, Azure AI, or on another cluster — from one place.
        </p>
        <ul class="mt-4 space-y-1.5 text-xs text-slate-500">
          <li class="flex items-center gap-2"><span class="text-plate-400">✓</span> Multi-provider: local, Bedrock, Vertex, Azure</li>
          <li class="flex items-center gap-2"><span class="text-plate-400">✓</span> GitOps promotion via ArgoCD + Crossplane</li>
          <li class="flex items-center gap-2"><span class="text-plate-400">✓</span> SLOs, blast radius, evals, cost tracking</li>
        </ul>
      </div>

    </div>
  </div>
</section>

<!-- ─── AGENT FACTORY DEEP DIVE ─────────────────────────────────────────────── -->
<section id="agent-factory" class="py-28 border-t border-white/5 relative overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-b from-plate-950/0 via-plate-950/50 to-plate-950/0 pointer-events-none"></div>
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[400px] bg-plate-700/8 rounded-full blur-[100px] pointer-events-none"></div>

  <div class="relative max-w-6xl mx-auto px-6">
    <div class="text-center mb-16">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-plate-500/10 border border-plate-500/20 text-plate-300 text-sm font-medium mb-4">
        Agent Factory
      </div>
      <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">
        Your teams are already building AI agents.<br/>
        <span class="text-plate-400">Nobody's governing them.</span>
      </h2>
      <p class="text-slate-400 text-lg max-w-2xl mx-auto">
        Some are on AWS. Some on Azure. Some a developer spun up last week on their laptop.
        Nobody knows what they cost. Nobody knows what data they can touch.
      </p>
    </div>

    <!-- the gap -->
    <div class="grid md:grid-cols-2 gap-8 mb-16">
      <div class="p-6 rounded-2xl bg-red-950/30 border border-red-500/20">
        <h3 class="text-red-400 font-semibold mb-4 flex items-center gap-2">
          <span>✗</span> Today — without Agent Factory
        </h3>
        <ul class="space-y-3 text-sm text-slate-400">
          {[
            'Spreadsheet tracks "maybe 12 agents?" — already out of date',
            'No idea what each agent can write to',
            '$4k/month billing agent — who owns it?',
            'Customer-facing agent giving wrong answers since Tuesday — what changed?',
            'Promoting dev→prod means copying YAML and praying',
            'Cloud credentials scattered across team laptops',
          ].map(item => (
            <li class="flex items-start gap-2">
              <span class="text-red-500 mt-0.5 flex-shrink-0">—</span>
              {item}
            </li>
          ))}
        </ul>
      </div>
      <div class="p-6 rounded-2xl bg-emerald-950/30 border border-emerald-500/20">
        <h3 class="text-emerald-400 font-semibold mb-4 flex items-center gap-2">
          <span>✓</span> With Agent Factory
        </h3>
        <ul class="space-y-3 text-sm text-slate-400">
          {[
            '23 agents, 6 teams, all statuses visible in one dashboard',
            'Blast radius analysis — see every system an agent can write to before promotion',
            'Cost per agent, per team, per month — live',
            'Prompt lineage: every change is a git commit correlated to eval results',
            'dev→staging→prod is a one-click GitOps workflow',
            'No cloud credentials in Agent Factory — Crossplane + ArgoCD handle it',
          ].map(item => (
            <li class="flex items-start gap-2">
              <span class="text-emerald-500 mt-0.5 flex-shrink-0">✓</span>
              {item}
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- how it works -->
    <div class="rounded-2xl border border-white/8 overflow-hidden">
      <div class="px-6 py-4 border-b border-white/8 bg-white/3">
        <h3 class="text-white font-semibold">How Agent Factory works — two paths, one API</h3>
      </div>
      <div class="grid md:grid-cols-2 divide-y md:divide-y-0 md:divide-x divide-white/8">
        <div class="p-6">
          <div class="text-xs text-plate-400 font-mono font-medium mb-3 uppercase tracking-wider">Path A — Local agents</div>
          <div class="space-y-2 font-mono text-sm">
            {[
              ['text-slate-400', 'POST /agents/billing-assistant/invoke'],
              ['text-slate-500', '  ↓ load agent config from K8s ConfigMap'],
              ['text-slate-500', '  ↓ resolve tool URLs from tool catalog'],
              ['text-slate-500', '  ↓ POST /api/chat → ai-chat-api'],
              ['text-emerald-400', '  ↓ LLM calls Jira, Postgres, Slack tools'],
              ['text-slate-500', '  ↓ store Run ConfigMap (trace + usage)'],
              ['text-plate-300', '  ← return { output, steps, cost }'],
            ].map(([cls, line]) => (
              <div class={cls}>{line}</div>
            ))}
          </div>
        </div>
        <div class="p-6">
          <div class="text-xs text-violet-400 font-mono font-medium mb-3 uppercase tracking-wider">Path B — Cloud / Remote agents (via GitOps)</div>
          <div class="space-y-2 font-mono text-sm">
            {[
              ['text-slate-400', 'POST /agents/research-agent/promote'],
              ['text-slate-500', '  ↓ commit manifest to Git'],
              ['text-slate-500', '    agents/production/research-agent.yaml'],
              ['text-violet-400', '  ↓ ArgoCD detects commit → syncs'],
              ['text-slate-500', '  ↓ Crossplane provisions Bedrock agent'],
              ['text-slate-500', '  ↓ AF watches status → updates registry'],
              ['text-plate-300', '  ← agent live in production'],
            ].map(([cls, line]) => (
              <div class={cls}>{line}</div>
            ))}
          </div>
        </div>
      </div>
    </div>

    <!-- key differentiators -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 mt-8">
      {[
        { icon: '🎯', title: 'Blast Radius Analysis', body: 'Know exactly what every agent can touch before it goes to production.' },
